# ============================================================
# DM Life — Konfiguration (Yuvomi-style single-container)
# Kopieren nach .env und anpassen. Alle Werte sind optional bis auf
# SESSION_SECRET (wird vom Installer automatisch generiert, wenn leer).
# ============================================================

# Laufzeitumgebung
NODE_ENV=production

# HTTP-Port innerhalb des Containers (Host-Port via Compose)
PORT=3000

# Datenbank + Datenverzeichnis
DB_PATH=/data/dm-life.db
DATA_DIR=/data

# Sicherheit: SESSION_SECRET — MINDESTENS 32 Zeichen!
# Leer lassen → Installer erzeugt einen und schreibt ihn nach /data/.env.auto
SESSION_SECRET=

# Cookies: true wenn hinter HTTPS-Reverse-Proxy (Caddy/Traefik/...)
# false für direkten HTTP-Zugriff (z.B. LAN IP)
SESSION_SECURE=false

# Vertrauenswürdiger Proxy-Hop (1 = eine Proxy-Ebene, z.B. Caddy)
TRUST_PROXY=1

# Brute-Force-Schutz für Login
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_ATTEMPTS=8
