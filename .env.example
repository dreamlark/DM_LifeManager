# dm-life NAS 部署环境变量
# 用法：复制本文件为 .env，用强随机值替换下面两项（缺失则服务启动即失败）。
#
# 在 NAS 终端用以下命令生成（各生成一次，分别填入）：
#   openssl rand -base64 48
#
# 说明：
#   JWT_SECRET      —— server 的 JWT 签名密钥，必须强随机、不要留空或提交到仓库。
#   ENGINE_API_TOKEN—— engine 与 server 共用的引擎访问令牌，两者必须一致，
#                       且为同一强随机值（浏览器登录后从 server 获取并随请求携带）。

JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_48
ENGINE_API_TOKEN=CHANGE_ME_use_openssl_rand_base64_48
