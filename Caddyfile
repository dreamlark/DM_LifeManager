{
  # 替换为你的管理员邮箱（Caddy 用于申请 Let's Encrypt 证书）
  email admin@{$DOMAIN}
}

{$DOMAIN} {
  encode zstd gzip

  # 本地引擎（个人模式 / SSE / 就绪探测）：剥离 /engine 前缀后再转发，
  # 使 engine 收到原生 /trpc / /events / /_routes。
  # 安全（P0-2）：engine 启用 ENGINE_API_TOKEN 后，仅接受携带正确令牌的请求；
  # 浏览器经已登录会话从 server 获取该令牌并随请求携带，匿名者无法访问。
  # 防御纵深：若仅家庭内网使用，可在此块加 `basicauth` 或限制来源 IP；
  # 切勿在未设 ENGINE_API_TOKEN 时把 /engine 暴露到公网。
  handle_path /engine/* {
    reverse_proxy engine:14570
  }

  # 协作后端 tRPC（保留 /trpc 前缀，server 端点即 /trpc）
  handle /trpc* {
    reverse_proxy server:4100
  }

  # 版本接口
  handle /api/* {
    reverse_proxy server:4100
  }

  # 健康检查（前端 BackendGate 探测）
  handle /health* /ready* {
    reverse_proxy server:4100
  }

  # 实时 WebSocket 网关
  handle /ws* {
    reverse_proxy server:4100
  }

  # 默认：前端静态站（Web + 移动 PWA 共用）
  handle {
    reverse_proxy frontend:80
  }
}
