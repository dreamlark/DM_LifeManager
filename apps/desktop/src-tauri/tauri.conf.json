{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DM_life",
  "version": "0.1.0",
  "identifier": "com.dm-life.app",
  "build": {
    "frontendDist": "../../packages/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DM_life",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
