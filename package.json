{
  "name": "dm-life",
  "private": true,
  "version": "0.1.0",
  "description": "DM_life 人生管理系统 — TypeScript + React + Vite + Tauri 2 全新实现 (P0)",
  "workspaces": [
    "packages/shared",
    "packages/engine",
    "packages/web",
    "apps/desktop"
  ],
  "scripts": {
    "dev:engine": "npm run dev -w packages/engine",
    "dev:web": "npm run dev -w packages/web",
    "dev:clean": "node scripts/dev-clean.mjs",
    "dev:clean:y": "node scripts/dev-clean.mjs -y",
    "dev:all": "npm run dev:clean -y && npm run dev:engine",
    "build": "npm run build -w packages/web",
    "test": "npm run test -w packages/engine",
    "studio": "npm run studio -w packages/engine"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
