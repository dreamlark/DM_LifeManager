{
  "name": "dm-life",
  "version": "2.0.0",
  "description": "人生管理系统 — Yuvomi-style rewrite: single Express + better-sqlite3, zero-build PWA frontend.",
  "type": "module",
  "main": "server/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node --import dotenv/config server/index.js",
    "dev": "node --import dotenv/config --watch server/index.js",
    "setup": "node --import dotenv/config setup.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "express-session": "^1.19.0",
    "helmet": "^8.3.0"
  },
  "license": "MIT",
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "bcrypt@6.0.0": true
  }
}
